<%- include('partials/admin-topp', { tittel: 'Referanser', aktiv: 'referansar' }) %>

<p class="a-melding a-melding-info">⚠️ Husk: innhent alltid samtykke fra kunden før dere publiserer navn eller omtale. Kommer omtalen fra Google, skriv «fra Google-omtaler» i kildefeltet.</p>

<section class="a-seksjon">
  <form method="post" action="/admin/referansar/vis">
    <label class="a-slett"><input type="checkbox" name="vis" <%= c.referansar.vis ? 'checked' : '' %>> Vis referanser på forsiden</label>
    <button class="a-knapp" type="submit">Lagre valg</button>
  </form>
</section>

<% c.referansar.liste.forEach((r) => { %>
<section class="a-seksjon">
  <form method="post" action="/admin/referansar/<%= r.id %>">
    <label for="tekst-<%= r.id %>">Omtale</label>
    <textarea id="tekst-<%= r.id %>" name="tekst" rows="3"><%= r.tekst %></textarea>
    <div class="a-rad-3">
      <div><label for="namn-<%= r.id %>">Navn</label><input id="namn-<%= r.id %>" name="namn" value="<%= r.namn %>"></div>
      <div><label for="kjelde-<%= r.id %>">Kilde</label><input id="kjelde-<%= r.id %>" name="kjelde" value="<%= r.kjelde %>" placeholder="F.eks. fra Google-omtaler"></div>
    </div>
    <div class="a-knapp-rad">
      <button class="a-knapp" type="submit">Lagre</button>
      <label class="a-slett"><input type="checkbox" name="slett"> Slett når jeg lagrer</label>
    </div>
  </form>
</section>
<% }) %>

<section class="a-seksjon a-seksjon-ny">
  <h2>➕ Ny referanse</h2>
  <form method="post" action="/admin/referansar/ny">
    <label for="ny-tekst">Omtale</label>
    <textarea id="ny-tekst" name="tekst" rows="3" placeholder="Det kunden sa …"></textarea>
    <div class="a-rad-3">
      <div><label for="ny-namn">Navn</label><input id="ny-namn" name="namn"></div>
      <div><label for="ny-kjelde">Kilde</label><input id="ny-kjelde" name="kjelde"></div>
    </div>
    <button class="a-knapp" type="submit">Legg til</button>
  </form>
</section>

<%- include('partials/admin-botn') %>
