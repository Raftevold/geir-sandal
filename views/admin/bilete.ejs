<%- include('partials/admin-topp', { tittel: 'Bilder', aktiv: 'bilete' }) %>

<p class="a-ingress">Bildene komprimeres og tilpasses nettsiden automatisk. Skriv en god alt-tekst på hvert bilde – det er viktig for blinde og svaksynte, og for Google.</p>

<section class="a-seksjon">
  <h2>Last opp nye bilder</h2>
  <form method="post" action="/admin/bilete/opplast" enctype="multipart/form-data">
    <div class="a-dropsone" data-forhand="#forhand-ny" role="button" tabindex="0" aria-label="Last opp bilder – klikk eller dra filer hit">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 16V6M7 11l5-5 5 5M4 19h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <p><strong>Dra og slipp bilder hit</strong> – eller klikk for å velge filer</p>
      <p class="a-svak">JPG, PNG eller WebP · flere om gangen · komprimeres automatisk</p>
      <input id="filer" name="filer" type="file" accept="image/*" multiple>
    </div>
    <div id="forhand-ny" class="a-forhand"></div>
    <button class="a-knapp" type="submit">Last opp</button>
  </form>
</section>

<% if (c.bilete.length) { %>
<section class="a-seksjon">
  <h2>Bildearkivet (<%= c.bilete.length %>)</h2>
  <div class="a-bilete-rad">
    <% c.bilete.forEach((b) => { %>
      <figure class="a-bilete-kort">
        <img src="/media/<%= b.fil %>" alt="<%= b.alt %>" loading="lazy" width="220" height="147">
        <figcaption><%= b.fil %></figcaption>
        <p class="a-bruk">
          <% (bruk[b.fil] || []).forEach((kvar) => { %><span class="a-chip a-chip-ok"><%= kvar %></span><% }) %>
          <% if (!(bruk[b.fil] || []).length) { %><span class="a-chip">Ikke i bruk ennå</span><% } %>
        </p>
        <form method="post" action="/admin/bilete/<%= encodeURIComponent(b.fil) %>/alt">
          <label for="alt-<%= b.fil %>">Alt-tekst</label>
          <input id="alt-<%= b.fil %>" name="alt" value="<%= b.alt %>" maxlength="150">
          <button class="a-knapp a-knapp-liten" type="submit">Lagre alt-tekst</button>
        </form>
        <form method="post" action="/admin/bilete/<%= encodeURIComponent(b.fil) %>/slett" data-confirm="Slette bildet «<%= b.fil %>»? Det fjernes også fra sider som bruker det.">
          <button class="a-knapp a-knapp-raud a-knapp-liten" type="submit">Slett</button>
        </form>
      </figure>
    <% }) %>
  </div>
</section>
<% } else { %>
<p class="a-ingress">Ingen bilder er lastet opp ennå. Sidene bruker tydelig merkede plassholdere til dere laster opp egne foto.</p>
<% } %>

<%- include('partials/admin-botn') %>
