<%- include('partials/admin-topp', { tittel: 'Bilder', aktiv: 'bilete' }) %>

<p class="a-ingress">Bildene komprimeres og tilpasses nettsiden automatisk. Etter opplasting kan du bruke dem som hero-bilde, på tjenester og i prosjekter. Skriv alltid en god alt-tekst – det er viktig for blinde og svaksynte, og for Google.</p>

<section class="a-seksjon">
  <h2>Last opp</h2>
  <form method="post" action="/admin/bilete/opplast" enctype="multipart/form-data">
    <label for="filer">Velg bilder (du kan velge flere)</label>
    <input id="filer" name="filer" type="file" accept="image/*" multiple required>
    <label for="alt">Alt-tekst (hva viser bildet?)</label>
    <input id="alt" name="alt" placeholder="F.eks. Gravemaskin i arbeid på tomt i Deknepollen" maxlength="150">
    <button class="a-knapp" type="submit">Last opp</button>
  </form>
</section>

<% if (c.bilete.length) { %>
<section class="a-seksjon">
  <h2>Opplastede bilder (<%= c.bilete.length %>)</h2>
  <div class="a-bilete-rad">
    <% c.bilete.forEach((b) => { %>
      <figure class="a-bilete-kort">
        <img src="/media/<%= b.fil %>" alt="<%= b.alt %>" loading="lazy" width="200" height="130">
        <figcaption><%= b.fil %></figcaption>
        <form method="post" action="/admin/bilete/<%= encodeURIComponent(b.fil) %>/alt">
          <label for="alt-<%= b.fil %>">Alt-tekst</label>
          <input id="alt-<%= b.fil %>" name="alt" value="<%= b.alt %>" maxlength="150">
          <button class="a-knapp a-knapp-liten" type="submit">Lagre alt-tekst</button>
        </form>
        <form method="post" action="/admin/bilete/<%= encodeURIComponent(b.fil) %>/slett" data-confirm="Slette bildet «<%= b.fil %>»? Det fjernes også fra sider som bruker det.">
          <button class="a-knapp a-knapp-raud a-knapp-liten" type="submit">Slett</button>
        </form>
      </figure>
    <% }) %>
  </div>
</section>
<% } else { %>
<p>Ingen bilder er lastet opp ennå. Sidene bruker tydelig merkede plassholdere til dere laster opp egne foto.</p>
<% } %>

<%- include('partials/admin-botn') %>
