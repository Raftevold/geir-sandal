<div class="a-stat-rad">
  <a class="a-stat" href="/admin/tenester"><strong><%= c.tenester.length %></strong><span>tjenester</span></a>
  <a class="a-stat" href="/admin/prosjekt"><strong><%= c.prosjekt.liste.length %></strong><span>prosjekter</span></a>
  <a class="a-stat" href="/admin/bilete"><strong><%= c.bilete.length %></strong><span>bilder</span></a>
  <a class="a-stat" href="/admin/forespurnader"><strong><%= talSubmissions %></strong><span>henvendelser</span></a>
</div>

<div class="a-kort-rad">
  <a class="a-kort" href="/admin/tekst"><strong>📝 Tekst og forside</strong><span>Overskrifter, nøkkeltall og «om oss»</span></a>
  <a class="a-kort" href="/admin/bilete"><strong>🖼️ Last opp bilder</strong><span>Dra og slipp – med forhåndsvisning</span></a>
  <a class="a-kort" href="/admin/prosjekt"><strong>🏗️ Vis frem et prosjekt</strong><span>Nye referanser selger best</span></a>
  <a class="a-kort" href="/admin/varsel"><strong>📣 Varsellinje</strong><span>Ferie, kampanjer og driftsmeldinger</span></a>
  <a class="a-kort" href="/admin/hjelp"><strong>📖 Brukerhåndbok</strong><span>Kort forklaring på alt i admin</span></a>
</div>

<section class="a-seksjon">
  <h2>Status</h2>
  <ul class="a-status">
    <li><span class="a-chip <%= lager === 'lokal' ? 'a-chip-obs' : 'a-chip-ok' %>"><%= lager === 'postgres' ? 'Database' : lager === 'github' ? 'GitHub' : 'Bare lokalt' %></span> Langtidslagring: <%= lager === 'postgres' ? 'endringer og bilder overlever omstart og redeploy' : lager === 'github' ? 'endringer overlever omstart og redeploy' : 'endringer kan gå tapt ved redeploy' %></li>
    <li><span class="a-chip <%= smtpAktiv ? 'a-chip-ok' : '' %>"><%= smtpAktiv ? 'Aktiv' : 'Ikke satt opp' %></span> E-postvarsling: <%= smtpAktiv ? 'henvendelser sendes på e-post' : 'henvendelser finner du bare under «Henvendelser»' %></li>
    <li><span class="a-chip <%= sitePublic ? 'a-chip-ok' : 'a-chip-obs' %>"><%= sitePublic ? 'Åpen' : 'Demo' %></span> <%= sitePublic ? 'Siden er åpen for søkemotorer (Google kan indeksere).' : 'Demo-modus: siden er skjult for søkemotorer (noindex) til den er godkjent.' %></li>
  </ul>
</section>

