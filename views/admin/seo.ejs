<%- include('partials/admin-topp', { tittel: 'SEO – titler og beskrivelser', aktiv: 'seo' }) %>

<p class="a-ingress">Tittelen og beskrivelsen er det folk ser i Google-søk. Hold tittelen under ca. 60 tegn og beskrivelsen under ca. 155 tegn. Usikker på hva SEO er? <a href="/admin/hjelp#seo">Se håndboken</a>.</p>

<section class="a-seksjon">
  <form method="post" action="/admin/seo">
    <% const namn = { heim: 'Forsiden', tenester: 'Tjenester', prosjekt: 'Prosjekter', omOss: 'Om oss', kontakt: 'Kontakt', personvern: 'Personvern' }; %>
    <% Object.keys(c.seo).forEach((side) => { %>
      <fieldset>
        <legend><%= namn[side] || side %></legend>
        <label for="tittel_<%= side %>">Tittel</label>
        <input id="tittel_<%= side %>" name="tittel_<%= side %>" value="<%= c.seo[side].tittel %>" maxlength="70">
        <label for="beskriving_<%= side %>">Beskrivelse</label>
        <textarea id="beskriving_<%= side %>" name="beskriving_<%= side %>" rows="2" maxlength="170"><%= c.seo[side].beskriving %></textarea>
      </fieldset>
    <% }) %>
    <button class="a-knapp" type="submit">Lagre SEO</button>
  </form>
</section>

<%- include('partials/admin-botn') %>
