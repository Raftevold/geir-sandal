<%- include('partials/admin-topp', { tittel: 'Prosjekter', aktiv: 'prosjekt' }) %>

<p class="a-ingress">Prosjektene vises på /prosjekter – nye referanser selger best. Klikk på et prosjekt for å redigere det, eller last opp bilder direkte når du oppretter et nytt.</p>

<% c.prosjekt.liste.forEach((p) => { const forsteBilde = c.bilete.find((b) => b.fil === p.bilete[0]); %>
<details class="a-element">
  <summary>
    <% if (forsteBilde) { %><img class="a-mini" src="/media/<%= forsteBilde.fil %>" alt="" loading="lazy" width="52" height="38"><% } else { %><span class="a-mini-tom">Foto</span><% } %>
    <%= p.tittel %>
    <% if (p.bilete.length) { %><span class="a-svak"><%= p.bilete.length %> bilde<%= p.bilete.length === 1 ? '' : 'r' %></span><% } %>
  </summary>
  <div class="a-element-innhald">
    <form method="post" action="/admin/prosjekt/<%= p.id %>" enctype="multipart/form-data">
      <label for="tittel-<%= p.id %>">Tittel</label>
      <input id="tittel-<%= p.id %>" name="tittel" value="<%= p.tittel %>" maxlength="80">
      <label for="skildring-<%= p.id %>">Beskrivelse</label>
      <textarea id="skildring-<%= p.id %>" name="skildring" rows="4"><%= p.skildring %></textarea>

      <fieldset>
        <legend>Bilder (velg så mange du vil)</legend>
        <%- include('partials/bileteveljar', { namn: 'bilete', vald: p.bilete, fleirval: true, tomEtikett: '' }) %>
        <%- include('partials/filfelt', { namn: 'nyeBilete', fleire: true, etikett: 'Eller last opp nye bilder direkte' }) %>
      </fieldset>

      <div class="a-knapp-rad">
        <button class="a-knapp" type="submit">Lagre</button>
        <label class="a-slett"><input type="checkbox" name="slett"> Slett prosjektet når jeg lagrer</label>
      </div>
    </form>
  </div>
</details>
<% }) %>

<section class="a-seksjon a-seksjon-ny">
  <h2>➕ Nytt prosjekt</h2>
  <form method="post" action="/admin/prosjekt/ny" enctype="multipart/form-data">
    <label for="ny-tittel">Tittel</label>
    <input id="ny-tittel" name="tittel" maxlength="80" placeholder="F.eks. Tomtegraving, Måløy">
    <label for="ny-skildring">Beskrivelse</label>
    <textarea id="ny-skildring" name="skildring" rows="3"></textarea>
    <% if (c.bilete.length) { %>
    <fieldset>
      <legend>Velg fra bildearkivet (valgfritt)</legend>
      <%- include('partials/bileteveljar', { namn: 'bilete', vald: [], fleirval: true, tomEtikett: '' }) %>
    </fieldset>
    <% } %>
    <%- include('partials/filfelt', { namn: 'nyeBilete', fleire: true, etikett: 'Last opp bilder (valgfritt)' }) %>
    <button class="a-knapp" type="submit">Opprett prosjekt</button>
  </form>
</section>

<%- include('partials/admin-botn') %>
