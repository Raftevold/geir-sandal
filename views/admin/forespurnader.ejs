<%- include('partials/admin-topp', { tittel: 'Henvendelser', aktiv: 'forespurnader' }) %>

<p class="a-ingress">Innsendte kontaktskjema. Husk å slette henvendelser når de er ferdig behandlet (personvern).</p>

<% if (liste.length === 0) { %>
  <p>Ingen henvendelser ennå.</p>
<% } %>

<% liste.forEach((s) => { %>
<section class="a-seksjon">
  <h2><%= s.namn %> <span class="a-svak"><%= new Date(s.tidspunkt).toLocaleString('nb-NO', { dateStyle: 'short', timeStyle: 'short' }) %></span></h2>
  <ul class="a-status">
    <% if (s.telefon) { %><li>📞 <a href="tel:<%= s.telefon.replace(/\s/g,'') %>"><%= s.telefon %></a></li><% } %>
    <% if (s.epost) { %><li>✉️ <a href="mailto:<%= s.epost %>"><%= s.epost %></a></li><% } %>
    <li><%= s.epostSendt ? '✅ Sendt videre på e-post' : 'ℹ️ Ikke sendt på e-post (e-postvarsling ikke satt opp)' %></li>
  </ul>
  <blockquote class="a-sitat"><%= s.melding %></blockquote>
  <form method="post" action="/admin/forespurnader/<%= s.id %>/slett" data-confirm="Slette henvendelsen fra <%= s.namn %>?">
    <button class="a-knapp a-knapp-raud a-knapp-liten" type="submit">Slett</button>
  </form>
</section>
<% }) %>

<%- include('partials/admin-botn') %>
