<% /* Direkteopplasting i kontekst. Parametre: namn (feltnavn), fleire (bool), etikett */ %>
<div class="a-filfelt">
  <label class="a-filfelt-knapp">
    <svg viewBox="0 0 20 20" aria-hidden="true" focusable="false"><path d="M10 14V4M6 8l4-4 4 4M4 16h12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <%= etikett %>
    <input type="file" name="<%= namn %>" accept="image/*" <%= fleire ? 'multiple' : '' %>>
  </label>
  <p class="a-filfelt-vald" aria-live="polite"></p>
</div>
