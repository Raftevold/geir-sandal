<!DOCTYPE html>
<html lang="nb">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title><%= tittel %> – Admin – Geir Sandal</title>
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/css/admin.css?v=<%= assetV %>">
</head>
<body>
<div class="a-oppsett">
<aside class="a-side" id="sidemeny">
  <a class="a-logo" href="/admin">
    <svg viewBox="0 0 64 48" aria-hidden="true" focusable="false"><rect x="8" y="20" width="18" height="12" rx="2.5" fill="currentColor"/><rect x="11" y="12" width="9" height="10" rx="2" fill="currentColor"/><path d="M26 22 L42 8 L46 12 L32 24 Z" fill="currentColor"/><path d="M42 8 L52 15 L47 21 L41.5 14 Z" fill="currentColor"/><rect x="6" y="34" width="26" height="8" rx="4" fill="currentColor" opacity="0.55"/></svg>
    <span>GEIR SANDAL<small>Administrasjon</small></span>
  </a>

  <nav aria-label="Adminmeny">
    <div class="a-gruppe">
      <ul class="a-meny">
        <li><a href="/admin" <%= aktiv === 'oversikt' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 10 L10 3l7 7v7h-5v-4H8v4H3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg> Oversikt</a></li>
      </ul>
    </div>
    <div class="a-gruppe">
      <p class="a-gruppe-tittel">Innhold</p>
      <ul class="a-meny">
        <li><a href="/admin/tekst" <%= aktiv === 'tekst' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 4h12M4 8h12M4 12h8M4 16h5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg> Tekst og forside</a></li>
        <li><a href="/admin/tenester" <%= aktiv === 'tenester' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M13.5 3.5a4 4 0 0 0-5.2 5L3 13.8V17h3.2l5.3-5.3a4 4 0 0 0 5-5.2l-2.6 2.6-2.4-2.4z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg> Tjenester</a></li>
        <li><a href="/admin/prosjekt" <%= aktiv === 'prosjekt' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M2.5 6.5v9h15v-7h-8l-2-2h-5z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M2.5 6.5v-2h5l2 2" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg> Prosjekter</a></li>
        <li><a href="/admin/referansar" <%= aktiv === 'referansar' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 4h14v9H8l-4 3.5V13H3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg> Referanser</a></li>
      </ul>
    </div>
    <div class="a-gruppe">
      <p class="a-gruppe-tittel">Media</p>
      <ul class="a-meny">
        <li><a href="/admin/bilete" <%= aktiv === 'bilete' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><rect x="3" y="4" width="14" height="12" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="7.5" cy="8.5" r="1.4" fill="currentColor"/><path d="M4 14l4-4 3 3 2.5-2.5L17 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg> Bilder</a></li>
      </ul>
    </div>
    <div class="a-gruppe">
      <p class="a-gruppe-tittel">Innstillinger</p>
      <ul class="a-meny">
        <li><a href="/admin/kontaktinfo" <%= aktiv === 'kontaktinfo' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4.5 3.5c.5-.5 1.3-.5 1.8 0l2 2c.5.5.5 1.3 0 1.8l-1 1c.6 1.4 2.5 3.3 3.9 3.9l1-1c.5-.5 1.3-.5 1.8 0l2 2c.5.5.5 1.3 0 1.8l-1.1 1.1c-.6.6-1.6.9-2.5.5-3.9-1.5-7.4-5-8.9-8.9-.4-.9-.1-1.9.5-2.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg> Kontaktinfo</a></li>
        <li><a href="/admin/varsel" <%= aktiv === 'varsel' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 8v4l3 .5V7.5zM6 7.5L15 4v12l-9-3.5z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M15.5 8.5a2.5 2.5 0 0 1 0 3" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg> Varsellinje</a></li>
        <li><a href="/admin/seo" <%= aktiv === 'seo' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="M12.5 12.5L17 17" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg> SEO</a></li>
      </ul>
    </div>
    <div class="a-gruppe">
      <p class="a-gruppe-tittel">Innboks</p>
      <ul class="a-meny">
        <li><a href="/admin/forespurnader" <%= aktiv === 'forespurnader' ? 'aria-current="page"' : '' %>><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5h14v10H3z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M3 6l7 5 7-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg> Henvendelser <% if (typeof talSubmissions !== 'undefined' && talSubmissions > 0) { %><span class="a-teljar"><%= talSubmissions %></span><% } %></a></li>
      </ul>
    </div>
  </nav>

  <div class="a-side-botn">
    <a href="/" target="_blank" rel="noopener"><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M8 4H4v12h12v-4M12 4h4v4M16 4l-7 7" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg> Se nettsiden</a>
    <form method="post" action="/admin/logout"><button type="submit"><svg viewBox="0 0 20 20" aria-hidden="true"><path d="M8 4H4v12h4M13 6l4 4-4 4M17 10H8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg> Logg ut</button></form>
  </div>
</aside>

<div>
  <div class="a-topplinje">
    <h1><%= tittel %></h1>
    <button class="a-burger" type="button" aria-expanded="false" aria-controls="sidemeny">☰ Meny</button>
  </div>
  <main class="a-hovud">
  <% if (typeof lagra !== 'undefined' && lagra) { %>
    <div class="a-toast" role="status">✓ Lagret. Endringen er synlig på nettsiden med en gang.</div>
  <% } %>
  <% if (typeof feil !== 'undefined' && feil) { %>
    <p class="a-melding a-melding-feil" role="alert"><%= feil %></p>
  <% } %>
