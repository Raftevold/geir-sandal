</main>

<div class="mobil-cta" aria-hidden="false">
  <a class="knapp knapp-primar" href="/kontakt#skjema">Be om tilbud</a>
  <a class="knapp knapp-lys" href="<%= telHref(c.site.telefon) %>">Ring <%= c.site.telefon %></a>
</div>

<footer class="botn">
  <p class="botn-ordmerke" aria-hidden="true">GEIR SANDAL</p>
  <div class="ramme botn-inner">
    <div>
      <p class="botn-logo"><strong>GEIR SANDAL</strong> AS</p>
      <p><%= c.site.slagord %></p>
      <p>Org.nr <%= c.site.orgnr %></p>
    </div>
    <div>
      <h2 class="botn-tittel">Kontakt</h2>
      <p><a href="<%= telHref(c.site.telefon) %>"><%= c.site.telefon %></a></p>
      <p><a href="mailto:<%= c.site.epost %>"><%= c.site.epost %></a></p>
      <p><%= c.site.adresse.gate %>, <%= c.site.adresse.postnr %> <%= c.site.adresse.stad %></p>
      <% if (c.site.opningstider) { %><p><%= c.site.opningstider %></p><% } %>
    </div>
    <div>
      <h2 class="botn-tittel">Snarveier</h2>
      <ul class="botn-meny">
        <li><a href="/tjenester">Tjenester</a></li>
        <li><a href="/prosjekter">Prosjekter</a></li>
        <li><a href="/om-oss">Om oss</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
        <li><a href="/personvern">Personvern</a></li>
      </ul>
      <% if (c.site.sosiale.facebook || c.site.sosiale.instagram) { %>
        <p>
          <% if (c.site.sosiale.facebook) { %><a href="<%= c.site.sosiale.facebook %>" rel="noopener">Facebook</a> <% } %>
          <% if (c.site.sosiale.instagram) { %><a href="<%= c.site.sosiale.instagram %>" rel="noopener">Instagram</a><% } %>
        </p>
      <% } %>
    </div>
  </div>
  <div class="ramme botn-linje">
    <p>© <%= new Date().getFullYear() %> <%= c.site.namn %>. Maskinentreprenør siden 1984.</p>
    <p>Sentralt godkjent foretak · Godkjent lærebedrift</p>
  </div>
</footer>

<script src="/js/main.js?v=<%= assetV %>" defer></script>
</body>
</html>
