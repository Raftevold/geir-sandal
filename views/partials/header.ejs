<% if (c.varsel.aktiv && c.varsel.tekst) { %>
  <% if (c.varsel.lenkje) { %>
    <a class="varsellinje" href="<%= c.varsel.lenkje %>"><span><%= c.varsel.tekst %></span><span class="varsel-pil" aria-hidden="true">→</span></a>
  <% } else { %>
    <div class="varsellinje"><span><%= c.varsel.tekst %></span></div>
  <% } %>
<% } %>

<div class="topplinje">
  <div class="ramme topplinje-inner">
    <span><%= c.site.slagord %></span>
    <span class="topplinje-kontakt">
      <a href="<%= telHref(c.site.telefon) %>"><svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true" focusable="false" style="vertical-align:-1px;"><path d="M3.3 1.2c.4-.4 1-.4 1.4 0l1.9 1.9c.4.4.4 1 0 1.4l-.9.9c.5 1.1 2 2.6 3.1 3.1l.9-.9c.4-.4 1-.4 1.4 0l1.9 1.9c.4.4.4 1 0 1.4l-1 1c-.5.5-1.3.7-2 .4-3.2-1.2-6-4-7.2-7.2-.3-.7-.1-1.5.4-2l1-1z" fill="currentColor"/></svg> <%= c.site.telefon %></a>
      <a class="skjul-mobil" href="mailto:<%= c.site.epost %>"><%= c.site.epost %></a>
    </span>
  </div>
</div>

<header class="hovudtopp">
  <div class="ramme hovudtopp-inner">
    <a class="logo" href="/">
      <svg class="logo-merke" viewBox="0 0 64 48" aria-hidden="true" focusable="false">
        <rect x="8" y="20" width="18" height="12" rx="2.5" fill="currentColor"/>
        <rect x="11" y="12" width="9" height="10" rx="2" fill="currentColor"/>
        <path d="M26 22 L42 8 L46 12 L32 24 Z" fill="currentColor"/>
        <path d="M42 8 L52 15 L47 21 L41.5 14 Z" fill="currentColor"/>
        <rect x="6" y="34" width="26" height="8" rx="4" fill="currentColor" opacity="0.55"/>
      </svg>
      <span class="logo-tekst"><strong>GEIR SANDAL</strong><span>Maskinentreprenør</span></span>
    </a>
    <nav aria-label="Hovedmeny">
      <button class="meny-knapp" type="button" aria-expanded="false" aria-controls="hovudmeny">
        <span class="meny-ikon" aria-hidden="true"></span> Meny
      </button>
      <ul id="hovudmeny" class="meny">
        <li><a href="/" <%= path === '/' ? 'aria-current="page"' : '' %>>Hjem</a></li>
        <li><a href="/tjenester" <%= path.startsWith('/tjenester') ? 'aria-current="page"' : '' %>>Tjenester</a></li>
        <li><a href="/prosjekter" <%= path === '/prosjekter' ? 'aria-current="page"' : '' %>>Prosjekter</a></li>
        <li><a href="/om-oss" <%= path === '/om-oss' ? 'aria-current="page"' : '' %>>Om oss</a></li>
        <li><a href="/kontakt" <%= path === '/kontakt' ? 'aria-current="page"' : '' %>>Kontakt</a></li>
        <li class="meny-cta"><a class="knapp knapp-primar" href="/kontakt#skjema">Be om tilbud</a></li>
      </ul>
    </nav>
  </div>
</header>

<main id="hovedinnhold">
